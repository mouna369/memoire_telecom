    "changelog": [
      "v3.8 FIX-19: connexion variantes (كوناكسيون/كونكسيو), ADSL (لادياسال), fibre (فيبروتيك/فايبر/فيبر), modem (مودام/المودام), Wi-Fi (ويفي/يفي), débit (ديبي), unités phonétiques (ميقا/جيقا), Mi Box, الفكس, google tv",
      "v3.8 FIX-20: arabizi_words — majozch, masma3nach, wana, rahom, 3lina, 3awdoulna, s7ab, nkhdmou, tdkhol, tl3b, dayrin, kdabin, barkaw, lo9doum, sebtembre, g33 et autres",
      "v3.8 FIX-21: telecom_tech — nokia/tenda/zte/huawei, mi box, airon, ethernet, gigabit, starlink, google tv, wi-fi, débit",
      "v3.8 FIX-22: french_corrections — sebtembre→septembre",
      "v3.7 FIX-14: mixed_ar_fr_regex — gaming/serveur/Fortnite/RAM/ligne/TV Box/promotion/موديم/ولله/Netflix/Amazon/prime vidéo",
      "v3.7 FIX-15: telecom_tech — twinbox, tv box, fortnite, netflix, prime video ajoutés",
      "v3.6 FIX-7 : unicode_arabic — suppression ئ→ي (détruisait سيئة→سييه)",
      "v3.6 FIX-8 : mixed_ar_fr_regex — ajout بينج→ping (variante de بينغ)",
      "v3.6 FIX-9 : mixed_ar_fr_regex — ajout بونيص/بونص→bonus",
      "v3.6 FIX-10: mixed_ar_fr_regex — ajout الكونيكسيو/الكنكسيون→الانترنت",
      "v3.6 FIX-11: mixed_ar_fr_regex — ajout نت (arabe)→الانترنت",
      "v3.6 FIX-12: mixed_ar_fr_regex — ajout انتارنات/انتارنت→الانترنت",
      "v3.6 FIX-13: arabizi_words — enrichissement dialecte algérien latin fréquent",
      "v3.5 FIX-1: arabizi_monograms a-z supprimées",
      "v3.5 FIX-2: unicode_arabic ajout ة→ه",
      "v3.5 FIX-3: mixed_ar_fr_regex ajout لافيبغ + variantes",
      "v3.5 FIX-4: telecom_tech ajout dsl, febre, cable, xgs-pon"
    ]
